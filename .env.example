# Supabase – copie para .env e preencha com as credenciais do seu projeto
# Nunca commite o .env – apenas o .env.example pode ser versionado
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_ANON_KEY=sua-chave-anon-publica

# Para Edge Functions com IA (Análise e Ações, etc.), configure OPENAI_API_KEY:
# 1. Supabase Dashboard → Project Settings → Edge Functions → Secrets
# 2. Ou via CLI: supabase secrets set OPENAI_API_KEY=sk-proj-...
