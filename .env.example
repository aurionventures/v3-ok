# ============================================================
# HANDOVER – Substitua estes 2 itens para novo servidor Supabase
# ============================================================
# 1. Project URL e Anon Key (obter em: Supabase → Settings → API)
# 2. OpenAI API Key (configurar em: Supabase → Edge Functions → Secrets)
#    Não vai aqui no .env; use: supabase secrets set OPENAI_API_KEY=sk-proj-...
# ============================================================

VITE_SUPABASE_URL=https://seu-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=sua-chave-anon-publica
