# Supabase – copie para .env e preencha com as credenciais do seu projeto
# Nunca commite o .env – apenas o .env.example pode ser versionado
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_ANON_KEY=sua-chave-anon-publica

# Para Edge Functions com IA, configure no Supabase Dashboard → Settings → Edge Functions → Secrets:
# OPENAI_API_KEY=sk-...
